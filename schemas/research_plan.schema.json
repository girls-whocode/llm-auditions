{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchPlan",
  "description": "Structured response contract for research query planner role",
  "type": "object",
  "required": ["question_decomposition", "search_queries", "source_requirements", "freshness_requirements", "official_source_requirements", "facts_requiring_verification", "stop_conditions"],
  "additionalProperties": false,
  "properties": {
    "question_decomposition": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Sub-questions broken from the main research question"
    },
    "search_queries": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source_requirements": {
      "type": "array",
      "items": {"type": "string"}
    },
    "freshness_requirements": {
      "type": "string"
    },
    "official_source_requirements": {
      "type": "array",
      "items": {"type": "string"}
    },
    "facts_requiring_verification": {
      "type": "array",
      "items": {"type": "string"}
    },
    "stop_conditions": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
