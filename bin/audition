#!/usr/bin/env python3
"""audition — LLM Audition Framework entry point."""
import sys
from pathlib import Path

# Allow running directly from bin/ without installation
_src = Path(__file__).parent.parent / "src"
if str(_src) not in sys.path:
    sys.path.insert(0, str(_src))

from llm_auditions.cli import main

if __name__ == "__main__":
    sys.exit(main())
