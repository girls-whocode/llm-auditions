# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
.eggs/
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Logs and Temp files
*.log
*.tmp
*.temp

# Results (runtime output — tracked separately or archived)
results/*/

# Secrets — never commit
*.key
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
.env
.env.*
secrets.yaml
secrets.json

# Editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Archive outputs (keep manifests but not tarballs)
*.tar.gz
*.sha256
